{
  "$meta": {
    "name": "Loboflix Design System",
    "version": "1.0",
    "themeDefault": "dark",
    "accent": "Apple-TV electric blue",
    "description": "Design tokens for Loboflix — a premium, dark-first film-scheduling app. Same token names in both themes; only values differ. Switch via a data-theme attribute on the root."
  },
  "color": {
    "dark": {
      "bg.base": "#0B0B0E",
      "bg.surface": "#131317",
      "bg.card": "#191920",
      "bg.elevated": "#22222B",
      "bg.overlay": "rgba(11,11,14,0.72)",
      "accent.primary": "#0A84FF",
      "accent.hover": "#3D9BFF",
      "accent.pressed": "#0069D9",
      "accent.deep": "#0055B8",
      "accent.disabled": "#1E3555",
      "accent.focusRing": "rgba(10,132,255,0.28)",
      "text.primary": "#F4F3F1",
      "text.secondary": "#9A99A0",
      "text.disabled": "#5A5A62",
      "border.default": "#2A2A33",
      "border.subtle": "#1C1C22",
      "feedback.success": "#5FBE86",
      "feedback.warning": "#E9A23B",
      "feedback.danger": "#E5615A",
      "feedback.info": "#6AA6E0"
    },
    "light": {
      "bg.base": "#F5F3EF",
      "bg.surface": "#FBFAF7",
      "bg.card": "#FFFFFF",
      "bg.elevated": "#FFFFFF",
      "bg.overlay": "rgba(20,18,16,0.40)",
      "accent.primary": "#0071E3",
      "accent.hover": "#2C8AF0",
      "accent.pressed": "#005BB8",
      "accent.disabled": "#B9D6F5",
      "accent.focusRing": "rgba(0,113,227,0.28)",
      "text.primary": "#1A1815",
      "text.secondary": "#6B6862",
      "text.disabled": "#A8A49C",
      "border.default": "#E4E0D8",
      "border.subtle": "#EEEBE4",
      "feedback.success": "#2E9E63",
      "feedback.warning": "#C77E1E",
      "feedback.danger": "#D23B34",
      "feedback.info": "#2F7DC4"
    }
  },
  "typography": {
    "fontFamilies": {
      "display": "'Space Grotesk', sans-serif",
      "body": "'Hanken Grotesk', sans-serif",
      "mono": "'JetBrains Mono', monospace"
    },
    "styles": {
      "display": { "family": "display", "size": 52, "lineHeight": 56, "weight": 600, "letterSpacing": "-0.03em" },
      "h1":      { "family": "display", "size": 36, "lineHeight": 40, "weight": 600, "letterSpacing": "-0.02em" },
      "h2":      { "family": "display", "size": 28, "lineHeight": 32, "weight": 600, "letterSpacing": "-0.02em" },
      "h3":      { "family": "display", "size": 22, "lineHeight": 28, "weight": 600, "letterSpacing": "-0.01em" },
      "title":   { "family": "body", "size": 18, "lineHeight": 24, "weight": 700, "letterSpacing": "0" },
      "subtitle":{ "family": "body", "size": 16, "lineHeight": 22, "weight": 600, "letterSpacing": "0" },
      "body":    { "family": "body", "size": 15, "lineHeight": 24, "weight": 400, "letterSpacing": "0" },
      "small":   { "family": "body", "size": 13, "lineHeight": 20, "weight": 400, "letterSpacing": "0" },
      "caption": { "family": "body", "size": 11, "lineHeight": 16, "weight": 500, "letterSpacing": "0.02em" },
      "button":  { "family": "body", "size": 15, "lineHeight": 15, "weight": 600, "letterSpacing": "0" },
      "label":   { "family": "mono", "size": 11, "lineHeight": 16, "weight": 500, "letterSpacing": "0.12em", "textTransform": "uppercase" }
    }
  },
  "spacing": { "1": 4, "2": 8, "3": 12, "4": 16, "5": 24, "6": 32, "8": 48, "10": 64, "base": 8 },
  "radius": { "xs": 4, "sm": 8, "md": 12, "lg": 18, "xl": 28, "full": 999 },
  "elevation": {
    "0": "none",
    "1": "0 2px 8px rgba(0,0,0,0.35)",
    "2": "0 8px 24px rgba(0,0,0,0.45)",
    "3": "0 20px 48px rgba(0,0,0,0.6)",
    "lightNote": "In light mode use soft near-black shadows for lift: rgba(26,24,21,0.06) to rgba(26,24,21,0.10)."
  },
  "grid": {
    "mobile":  { "maxWidth": 599,  "columns": 4,  "gutter": 16, "margin": 24, "posterRailPeek": 2.2 },
    "tablet":  { "minWidth": 600,  "columns": 8,  "gutter": 20, "margin": 40, "posterRailPeek": 4.3 },
    "desktop": { "minWidth": 1024, "columns": 12, "gutter": 24, "maxContent": 1200, "posterRailPeek": 6.5 }
  },
  "motion": {
    "duration": { "instant": 100, "fast": 200, "base": 320, "slow": 480 },
    "easing": {
      "standard": "cubic-bezier(0.2,0,0,1)",
      "decelerate": "cubic-bezier(0,0,0,1)",
      "spring": { "stiffness": 240, "damping": 26 }
    },
    "reducedMotion": "Replace all translate/scale transitions with opacity cross-fades. No parallax, spring, or shared-element flight."
  },
  "iconography": {
    "library": "Lucide",
    "stroke": 1.5,
    "sizes": [16, 20, 24, 32],
    "defaultInline": 20,
    "defaultNav": 24,
    "filledMeaning": "Active/selected state only (active tab, saved film, active rating). Outline is default/inactive."
  },
  "assets": {
    "posterAspect": "2:3",
    "backdropAspect": "16:9",
    "note": "Never crop off-ratio. Lazy-load posters. Use high-res source; no upscaling."
  }
}
